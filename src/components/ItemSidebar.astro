---
interface NavItem {
  slug: string;
  name: string;
}

interface Section {
  title: string | null;
  items: NavItem[];
}

interface Props {
  collectionTitle: string;
  collectionHref: string;
  sections: Section[];
  activeSlug?: string;
}

const { collectionTitle, collectionHref, sections, activeSlug } = Astro.props;
---

<div class="item-sidebar">
  <a class="book-title" href={collectionHref}>{collectionTitle}</a>
  {
    sections.map((section) => (
      <div class="chapter">
        {section.title && <div class="chapter-title">▸ {section.title}</div>}
        <ul>
          {section.items.map((item) => (
            <li>
              <a href={`/items/${item.slug}`} class={activeSlug === item.slug ? "active" : ""}>
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</div>
