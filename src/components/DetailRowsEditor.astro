---
import { t } from "../lib/i18n";

interface DetailRow {
  category: string;
  label: string;
  value: string;
}

interface Props {
  initialDetails?: DetailRow[];
  fieldName?: string;
}

const { initialDetails = [], fieldName = "details" } = Astro.props;
const seedRows = initialDetails.length > 0 ? initialDetails : [{ category: "", label: "", value: "" }];
const initialJson = JSON.stringify(seedRows);
const lang = Astro.locals.lang;
---

<div class="detail-rows-editor" data-initial={initialJson} data-remove-label={t(lang, "detailRows.remove")}>
  <table class="detail-table" id="detail-rows-table">
    <thead>
      <tr>
        <th>{t(lang, "detailRows.category")}</th>
        <th>{t(lang, "detailRows.label")}</th>
        <th>{t(lang, "detailRows.value")}</th>
        <th></th>
      </tr>
    </thead>
    <tbody id="detail-rows-body"></tbody>
  </table>
  <button type="button" id="add-detail-row" class="secondary-button">{t(lang, "detailRows.addField")}</button>
  <input type="hidden" name={fieldName} id="details-json" />
</div>

<script>
  interface DetailRow {
    category: string;
    label: string;
    value: string;
  }

  const container = document.querySelector<HTMLDivElement>(".detail-rows-editor");
  const body = document.getElementById("detail-rows-body") as HTMLTableSectionElement | null;
  const hiddenInput = document.getElementById("details-json") as HTMLInputElement | null;
  const addButton = document.getElementById("add-detail-row") as HTMLButtonElement | null;

  if (container && body && hiddenInput && addButton) {
    const initial: DetailRow[] = JSON.parse(container.getAttribute("data-initial") || "[]");
    const removeLabel = container.getAttribute("data-remove-label") || "Remove";

    const escapeAttr = (value: string) =>
      value.replace(/&/g, "&amp;").replace(/"/g, "&quot;").replace(/</g, "&lt;");

    function syncHidden() {
      const rows = Array.from(body!.querySelectorAll("tr"))
        .map((tr) => ({
          category: tr.querySelector<HTMLInputElement>(".row-category")?.value.trim() ?? "",
          label: tr.querySelector<HTMLInputElement>(".row-label")?.value.trim() ?? "",
          value: tr.querySelector<HTMLInputElement>(".row-value")?.value.trim() ?? "",
        }))
        .filter((r) => r.label && r.value);
      hiddenInput!.value = JSON.stringify(rows);
    }

    function addRow(row: DetailRow = { category: "", label: "", value: "" }) {
      const tr = document.createElement("tr");
      tr.innerHTML = `
        <td><input type="text" class="row-category" placeholder="Compute" value="${escapeAttr(row.category)}" /></td>
        <td><input type="text" class="row-label" placeholder="RAM" value="${escapeAttr(row.label)}" /></td>
        <td><input type="text" class="row-value" placeholder="16GB" value="${escapeAttr(row.value)}" /></td>
        <td><button type="button" class="remove-row secondary-button">${removeLabel}</button></td>
      `;
      tr.querySelector(".remove-row")?.addEventListener("click", () => {
        tr.remove();
        syncHidden();
      });
      tr.querySelectorAll("input").forEach((el) => el.addEventListener("input", syncHidden));
      body!.appendChild(tr);
    }

    addButton.addEventListener("click", () => {
      addRow();
      syncHidden();
    });

    for (const row of initial) addRow(row);
    syncHidden();

    container.closest("form")?.addEventListener("submit", syncHidden);
  }
</script>
