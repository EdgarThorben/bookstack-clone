---
interface Crumb {
  label: string;
  href: string;
  icon: string;
  current?: boolean;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;

const iconGlyph: Record<string, string> = {
  shelf: "▤",
  book: "■",
  chapter: "▸",
  page: "□",
};
---

<div class="bs-breadcrumb">
  {
    items.map((item, i) => (
      <>
        <span class="crumb">
          <span class={`icon icon-${item.icon}`}>{iconGlyph[item.icon]}</span>
          {item.current ? (
            <span class="current">{item.label}</span>
          ) : (
            <a href={item.href}>{item.label}</a>
          )}
        </span>
        {i < items.length - 1 && <span class="sep">&rsaquo;</span>}
      </>
    ))
  }
</div>
