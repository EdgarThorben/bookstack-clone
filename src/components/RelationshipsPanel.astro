---
import { actions } from "astro:actions";
import { relationshipTypes } from "../db/schema";
import { t, tItemType, tRelationshipType } from "../lib/i18n";

interface RelatedItem {
  slug: string;
  name: string;
  type: string;
}

interface Props {
  itemSlug: string;
  outgoing: { relationshipType: string; relatedItem: RelatedItem }[];
  incoming: { relationshipType: string; sourceItem: RelatedItem }[];
  otherItems: RelatedItem[];
  canEdit: boolean;
  relateError?: string;
}

const { itemSlug, outgoing, incoming, otherItems, canEdit, relateError } = Astro.props;
const lang = Astro.locals.lang;
---

<h2>{t(lang, "item.relationships")}</h2>
{relateError && <p class="login-error">{relateError}</p>}

<h3>{t(lang, "item.outgoing")}</h3>
{outgoing.length === 0 && <p class="no-changes">{t(lang, "item.noOutgoing")}</p>}
<ul class="relationship-list">
  {
    outgoing.map((r) => (
      <li>
        <span class="rel-type">{tRelationshipType(lang, r.relationshipType)}</span>
        <a href={`/items/${r.relatedItem.slug}`}>{r.relatedItem.name}</a>
        <span style="color:var(--bs-muted); font-size:0.85rem;">({tItemType(lang, r.relatedItem.type)})</span>
      </li>
    ))
  }
</ul>

<h3>{t(lang, "item.incoming")}</h3>
{incoming.length === 0 && <p class="no-changes">{t(lang, "item.noIncoming")}</p>}
<ul class="relationship-list">
  {
    incoming.map((r) => (
      <li>
        <a href={`/items/${r.sourceItem.slug}`}>{r.sourceItem.name}</a>
        <span class="rel-type">{tRelationshipType(lang, r.relationshipType)}</span>
        <span style="color:var(--bs-muted); font-size:0.85rem;">{t(lang, "item.thisItem")}</span>
      </li>
    ))
  }
</ul>

{
  canEdit && otherItems.length > 0 && (
    <form class="relate-form" method="POST" action={actions.addItemRelationship}>
      <input type="hidden" name="itemSlug" value={itemSlug} />
      <select name="relationshipType" required>
        {relationshipTypes.map((rt) => (
          <option value={rt}>{tRelationshipType(lang, rt)}</option>
        ))}
      </select>
      <select name="relatedItemSlug" required>
        {otherItems.map((i) => (
          <option value={i.slug}>{i.name} ({tItemType(lang, i.type)})</option>
        ))}
      </select>
      <button type="submit" class="secondary-button">{t(lang, "item.addRelationship")}</button>
    </form>
  )
}
