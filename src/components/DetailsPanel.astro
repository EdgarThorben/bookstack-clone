---
import type { PageDetail } from "../db/schema";
import { t } from "../lib/i18n";

interface Props {
  revision: number;
  createdBy: string;
  createdAgo: string;
  updatedBy: string;
  updatedAgo: string;
  revisionsHref: string;
  editHref?: string;
  exportData: PageDetail[];
  exportFilename: string;
  exportTitle: string;
}

const {
  revision,
  createdBy,
  createdAgo,
  updatedBy,
  updatedAgo,
  revisionsHref,
  editHref,
  exportData,
  exportFilename,
  exportTitle,
} = Astro.props;

const lang = Astro.locals.lang;

function toCsv(data: PageDetail[]) {
  const rows = [["Field", "Value"], ...data.map((d) => [d.label, d.value])];
  return rows
    .map((row) => row.map((cell) => `"${cell.replace(/"/g, '""')}"`).join(","))
    .join("\r\n");
}

function toJson(data: PageDetail[]) {
  const obj: Record<string, string> = {};
  for (const d of data) obj[d.label] = d.value;
  return JSON.stringify(obj, null, 2);
}

function toMarkdown(title: string, data: PageDetail[]) {
  let md = `# ${title}\n\n| Field | Value |\n| --- | --- |\n`;
  for (const d of data) md += `| ${d.label} | ${d.value} |\n`;
  return md;
}

const csvHref = `data:text/csv;charset=utf-8,${encodeURIComponent(toCsv(exportData))}`;
const jsonHref = `data:application/json;charset=utf-8,${encodeURIComponent(toJson(exportData))}`;
const mdHref = `data:text/markdown;charset=utf-8,${encodeURIComponent(toMarkdown(exportTitle, exportData))}`;
---

<div class="details-panel">
  <h4>{t(lang, "details.heading")}</h4>
  <ul>
    <li><span class="dot">&#8635;</span> {t(lang, "details.revision")} #{revision}</li>
    <li><span class="dot">&#9733;</span> {t(lang, "details.created")} {createdAgo} {t(lang, "details.by")} {createdBy}</li>
    <li><span class="dot">&#9998;</span> {t(lang, "details.updated")} {updatedAgo} {t(lang, "details.by")} {updatedBy}</li>
  </ul>
  <h4>{t(lang, "details.actions")}</h4>
  <div class="actions">
    {editHref && (
      <>
        <a href={editHref}><span class="dot">&#9998;</span> {t(lang, "details.edit")}</a>
        <hr class="thin" />
      </>
    )}
    <a href={revisionsHref}><span class="dot">&#8635;</span> {t(lang, "details.revisions")}</a>
    <hr class="thin" />
    <details class="export-menu">
      <summary><span class="dot">&#8615;</span> {t(lang, "details.export")}</summary>
      <div class="export-options">
        <a download={`${exportFilename}.csv`} href={csvHref}>{t(lang, "details.exportCsv")}</a>
        <a download={`${exportFilename}.json`} href={jsonHref}>{t(lang, "details.exportJson")}</a>
        <a download={`${exportFilename}.md`} href={mdHref}>{t(lang, "details.exportMarkdown")}</a>
      </div>
    </details>
  </div>
</div>
