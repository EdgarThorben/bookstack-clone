---
import { actions } from "astro:actions";
import { formatRelativeTime } from "../lib/time";
import { t } from "../lib/i18n";

interface CredentialRow {
  id: string;
  label: string;
  username: string;
  createdAt: Date;
  createdByName: string;
  revealCount: number;
}

interface Props {
  itemSlug: string;
  items: CredentialRow[];
  canEdit: boolean;
}

const { itemSlug, items, canEdit } = Astro.props;
const lang = Astro.locals.lang;
const revealLabel = t(lang, "credentials.reveal");
const hideLabel = t(lang, "credentials.hide");
---

<h2>{t(lang, "credentials.title")}</h2>
<p style="color:var(--bs-muted); font-size:0.9rem; max-width:60ch;">
  {t(lang, "credentials.notice")}
</p>

{items.length === 0 && <p class="no-changes">{t(lang, "credentials.none")}</p>}

<ul class="relationship-list">
  {
    items.map((c) => (
      <li class="credential-row" data-credential-id={c.id}>
        <span class="rel-type">{c.label}</span>
        <span>{c.username}</span>
        <span class="cred-secret masked">••••••••</span>
        {
          canEdit ? (
            <button
              type="button"
              class="reveal-btn secondary-button"
              data-reveal-label={revealLabel}
              data-hide-label={hideLabel}
            >
              {revealLabel}
            </button>
          ) : (
            <a href="/login" class="secondary-button">
              {t(lang, "credentials.loginToReveal")}
            </a>
          )
        }
        <span style="color:var(--bs-muted); font-size:0.78rem;">
          {c.revealCount} {c.revealCount === 1 ? t(lang, "credentials.revealOne") : t(lang, "credentials.revealMany")}
          {" "}&middot; {t(lang, "credentials.addedBy")}{" "}
          {formatRelativeTime(c.createdAt, lang)} {t(lang, "credentials.by")} {c.createdByName}
        </span>
      </li>
    ))
  }
</ul>

{
  canEdit && (
    <form class="relate-form" method="POST" action={actions.createCredential}>
      <input type="hidden" name="itemSlug" value={itemSlug} />
      <input type="text" name="label" placeholder={t(lang, "credentials.labelPlaceholder")} required />
      <input type="text" name="username" placeholder={t(lang, "credentials.usernamePlaceholder")} required />
      <input
        type="password"
        name="secret"
        placeholder={t(lang, "credentials.passwordPlaceholder")}
        required
        autocomplete="new-password"
      />
      <button type="submit" class="secondary-button">
        {t(lang, "credentials.add")}
      </button>
    </form>
  )
}

<script>
  import { actions } from "astro:actions";

  document.querySelectorAll<HTMLLIElement>(".credential-row").forEach((row) => {
    const btn = row.querySelector<HTMLButtonElement>(".reveal-btn");
    const secretEl = row.querySelector<HTMLElement>(".cred-secret");
    const credentialId = row.dataset.credentialId;
    if (!btn || !secretEl || !credentialId) return;

    const revealLabel = btn.dataset.revealLabel ?? "Reveal";
    const hideLabel = btn.dataset.hideLabel ?? "Hide";
    let revealedValue: string | null = null;

    btn.addEventListener("click", async () => {
      if (revealedValue !== null) {
        secretEl.textContent = "••••••••";
        secretEl.classList.add("masked");
        btn.textContent = revealLabel;
        revealedValue = null;
        return;
      }

      btn.disabled = true;
      const formData = new FormData();
      formData.set("credentialId", credentialId);
      const { data, error } = await actions.revealCredential(formData);
      btn.disabled = false;

      if (error) {
        secretEl.textContent = error.message;
        secretEl.classList.add("masked");
        return;
      }

      revealedValue = data.secret;
      secretEl.textContent = revealedValue;
      secretEl.classList.remove("masked");
      btn.textContent = hideLabel;
    });
  });
</script>
