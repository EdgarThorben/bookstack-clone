---
import { actions } from "astro:actions";
import { formatRelativeTime } from "../lib/time";

interface CredentialRow {
  id: string;
  label: string;
  username: string;
  createdAt: Date;
  createdByName: string;
  revealCount: number;
}

interface Props {
  assetSlug: string;
  items: CredentialRow[];
  canEdit: boolean;
}

const { assetSlug, items, canEdit } = Astro.props;
---

<h2>Credentials</h2>
<p style="color:var(--bs-muted); font-size:0.9rem; max-width:60ch;">
  Simulated for demo purposes — secrets are encrypted at rest (AES-256-GCM), masked by default,
  and every reveal is logged with who and when.
</p>

{items.length === 0 && <p class="no-changes">No credentials recorded for this asset.</p>}

<ul class="relationship-list">
  {
    items.map((c) => (
      <li class="credential-row" data-credential-id={c.id}>
        <span class="rel-type">{c.label}</span>
        <span>{c.username}</span>
        <span class="cred-secret masked">••••••••</span>
        {
          canEdit ? (
            <button type="button" class="reveal-btn secondary-button">
              Reveal
            </button>
          ) : (
            <a href="/login" class="secondary-button">
              Log in to reveal
            </a>
          )
        }
        <span style="color:var(--bs-muted); font-size:0.78rem;">
          {c.revealCount} reveal{c.revealCount === 1 ? "" : "s"} logged &middot; added{" "}
          {formatRelativeTime(c.createdAt)} by {c.createdByName}
        </span>
      </li>
    ))
  }
</ul>

{
  canEdit && (
    <form class="relate-form" method="POST" action={actions.createCredential}>
      <input type="hidden" name="assetSlug" value={assetSlug} />
      <input type="text" name="label" placeholder="Label (e.g. WordPress admin)" required />
      <input type="text" name="username" placeholder="Username / email" required />
      <input type="password" name="secret" placeholder="Password" required autocomplete="new-password" />
      <button type="submit" class="secondary-button">
        + Add Credential
      </button>
    </form>
  )
}

<script>
  import { actions } from "astro:actions";

  document.querySelectorAll<HTMLLIElement>(".credential-row").forEach((row) => {
    const btn = row.querySelector<HTMLButtonElement>(".reveal-btn");
    const secretEl = row.querySelector<HTMLElement>(".cred-secret");
    const credentialId = row.dataset.credentialId;
    if (!btn || !secretEl || !credentialId) return;

    let revealedValue: string | null = null;

    btn.addEventListener("click", async () => {
      if (revealedValue !== null) {
        secretEl.textContent = "••••••••";
        secretEl.classList.add("masked");
        btn.textContent = "Reveal";
        revealedValue = null;
        return;
      }

      btn.disabled = true;
      const formData = new FormData();
      formData.set("credentialId", credentialId);
      const { data, error } = await actions.revealCredential(formData);
      btn.disabled = false;

      if (error) {
        secretEl.textContent = error.message;
        secretEl.classList.add("masked");
        return;
      }

      revealedValue = data.secret;
      secretEl.textContent = revealedValue;
      secretEl.classList.remove("masked");
      btn.textContent = "Hide";
    });
  });
</script>
