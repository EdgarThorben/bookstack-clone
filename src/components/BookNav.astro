---
import { t } from "../lib/i18n";

interface NavPage {
  slug: string;
  title: string;
}

interface Props {
  bookTitle: string;
  bookHref: string;
  chapterTitle: string;
  chapterPages: NavPage[];
  otherPages: NavPage[];
  activeSlug?: string;
}

const { bookTitle, bookHref, chapterTitle, chapterPages, otherPages, activeSlug } = Astro.props;
const lang = Astro.locals.lang;
---

<div class="book-nav">
  <a class="book-title" href={bookHref}>{bookTitle}</a>
  <div class="chapter">
    <a class="chapter-title" href={bookHref}>▸ {chapterTitle}</a>
    <div class="page-count">{chapterPages.length} {t(lang, "bookNav.pages")}</div>
    <ul>
      {
        chapterPages.map((p) => (
          <li>
            <a
              href={`/books/it-department/page/${p.slug}`}
              class={activeSlug === p.slug ? "active" : ""}
            >
              {p.title}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
  <ul>
    {
      otherPages.map((p) => (
        <li>
          <a href={`/books/it-department/page/${p.slug}`} class={activeSlug === p.slug ? "active" : ""}>
            {p.title}
          </a>
        </li>
      ))
    }
  </ul>
</div>
