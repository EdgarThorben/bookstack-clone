---
import "../styles/global.css";
import { actions } from "astro:actions";
import { site } from "../config";

interface Props {
  title: string;
}

const { title } = Astro.props;
const user = Astro.locals.user;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | {site.name}</title>
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <header class="bs-header">
      <a href="/" class="brand">
        <svg class="bs-logo" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="2" y="4" width="20" height="4" rx="1" fill="#fff" fill-opacity="0.95"/>
          <rect x="2" y="10" width="20" height="4" rx="1" fill="#fff" fill-opacity="0.75"/>
          <rect x="2" y="16" width="20" height="4" rx="1" fill="#fff" fill-opacity="0.55"/>
        </svg>
        {site.name}
      </a>
      <div class="search" id="site-search">
        <input type="search" placeholder="Search" id="site-search-input" autocomplete="off" />
        <div class="search-results" id="site-search-results" hidden></div>
      </div>
      <nav>
        <a href="/">Shelves</a>
        <a href="/books">Books</a>
        {
          user ? (
            <span class="auth-status">
              Signed in as {user.displayName}
              <form method="POST" action={actions.logout} class="logout-form">
                <button type="submit" class="logout-button">Log out</button>
              </form>
            </span>
          ) : (
            <a href="/login">Log in</a>
          )
        }
      </nav>
    </header>
    <slot />
    <script>
      const input = document.getElementById("site-search-input") as HTMLInputElement;
      const results = document.getElementById("site-search-results") as HTMLDivElement;
      let index: { title: string; url: string; type: string; excerpt: string }[] | null = null;
      let activeIndex = -1;

      async function loadIndex() {
        if (index) return index;
        const res = await fetch("/search-index.json");
        index = await res.json();
        return index;
      }

      function render(matches: { title: string; url: string; type: string; excerpt: string }[]) {
        results.innerHTML = "";
        activeIndex = -1;
        if (matches.length === 0) {
          results.innerHTML = '<div class="search-empty">No matches found.</div>';
          results.hidden = false;
          return;
        }
        for (const m of matches.slice(0, 8)) {
          const a = document.createElement("a");
          a.href = m.url;
          a.className = "search-result";
          a.innerHTML = `<span class="sr-type">${m.type}</span><span class="sr-title">${m.title}</span><span class="sr-excerpt">${m.excerpt}</span>`;
          results.appendChild(a);
        }
        results.hidden = false;
      }

      input?.addEventListener("input", async () => {
        const q = input.value.trim().toLowerCase();
        if (!q) {
          results.hidden = true;
          return;
        }
        const data = await loadIndex();
        const matches = (data ?? []).filter(
          (e) => e.title.toLowerCase().includes(q) || e.excerpt.toLowerCase().includes(q)
        );
        render(matches);
      });

      input?.addEventListener("keydown", (e) => {
        const items = Array.from(results.querySelectorAll<HTMLAnchorElement>(".search-result"));
        if (e.key === "Escape") {
          results.hidden = true;
          return;
        }
        if (!items.length) return;
        if (e.key === "ArrowDown") {
          e.preventDefault();
          activeIndex = (activeIndex + 1) % items.length;
          items.forEach((el, i) => el.classList.toggle("active", i === activeIndex));
        } else if (e.key === "ArrowUp") {
          e.preventDefault();
          activeIndex = (activeIndex - 1 + items.length) % items.length;
          items.forEach((el, i) => el.classList.toggle("active", i === activeIndex));
        } else if (e.key === "Enter") {
          e.preventDefault();
          const target = activeIndex >= 0 ? items[activeIndex] : items[0];
          if (target) window.location.href = target.href;
        }
      });

      document.addEventListener("click", (e) => {
        if (!(e.target instanceof Node)) return;
        const wrap = document.getElementById("site-search");
        if (wrap && !wrap.contains(e.target)) {
          results.hidden = true;
        }
      });
    </script>
  </body>
</html>
