---
import BookStackLayout from "../layouts/BookStackLayout.astro";
---

<BookStackLayout title="Page Not Found">
  <div class="home-wrap" style="text-align:center; padding:4rem 1rem;">
    <h1 style="font-size:2.4rem; margin-bottom:0.5rem;">404</h1>
    <p style="color:var(--bs-muted); margin-bottom:1.5rem;">
      That page doesn't exist, or you don't have access to it.
    </p>
    <a class="new-page-link" href="/">Back to Shelves</a>
  </div>
</BookStackLayout>
