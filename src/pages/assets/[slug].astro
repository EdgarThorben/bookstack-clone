---
import BookStackLayout from "../../layouts/BookStackLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import DetailsPanel from "../../components/DetailsPanel.astro";
import CredentialsPanel from "../../components/CredentialsPanel.astro";
import { actions } from "astro:actions";
import { getAssetBySlug, getAssetRelationships, listAssets } from "../../lib/assetQueries";
import { getCredentialsForAsset } from "../../lib/credentialQueries";
import { groupDetailsByCategory } from "../../lib/details";
import { formatRelativeTime } from "../../lib/time";
import { relationshipTypes } from "../../db/schema";
import { t, tAssetType, tRelationshipType } from "../../lib/i18n";

const lang = Astro.locals.lang;
const { slug } = Astro.params;
const asset = slug ? await getAssetBySlug(slug) : null;

if (!asset) {
  Astro.response.status = 404;
  return Astro.rewrite("/404");
}

const relateResult = Astro.getActionResult(actions.addAssetRelationship);
const decommissionResult = Astro.getActionResult(actions.decommissionAsset);
const credentialResult = Astro.getActionResult(actions.createCredential);
if (
  (relateResult && !relateResult.error) ||
  (decommissionResult && !decommissionResult.error) ||
  (credentialResult && !credentialResult.error)
) {
  return Astro.redirect(`/assets/${asset.slug}`);
}

const categories = groupDetailsByCategory(asset.fields);
const { outgoing, incoming } = await getAssetRelationships(asset.id);
const otherAssets = (await listAssets()).filter((a) => a.id !== asset.id);
const credentialItems = await getCredentialsForAsset(asset.id);

const breadcrumbItems = [
  { label: t(lang, "nav.shelves"), href: "/", icon: "shelf" },
  { label: t(lang, "asset.title"), href: "/assets", icon: "book" },
  { label: asset.name, href: "", icon: "page", current: true },
];
---

<BookStackLayout title={asset.name}>
  <Breadcrumb items={breadcrumbItems} />
  <div class="bs-layout">
    <main class="bs-content">
      <h1>
        {asset.name}
        {asset.status === "decommissioned" && <span class="asset-status-badge">{t(lang, "asset.decommissioned")}</span>}
      </h1>
      <p style="color:var(--bs-muted);">{tAssetType(lang, asset.type)}</p>

      <h2>{t(lang, "asset.fields")}</h2>
      {categories.length === 0 && <p class="no-changes">{t(lang, "asset.noFields")}</p>}
      {
        categories.map((group) => (
          <details class="category-details" open>
            <summary>
              {group.category || t(lang, "asset.general")} <span class="cat-count">({group.items.length})</span>
            </summary>
            <div class="table-scroll">
              <table class="detail-table">
                <tbody>
                  {group.items.map((d) => (
                    <tr>
                      <th>{d.label}</th>
                      <td>{d.value}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </details>
        ))
      }

      <h2>{t(lang, "asset.relationships")}</h2>
      {(relateResult?.error) && <p class="login-error">{relateResult.error.message}</p>}

      <h3>{t(lang, "asset.outgoing")}</h3>
      {outgoing.length === 0 && <p class="no-changes">{t(lang, "asset.noOutgoing")}</p>}
      <ul class="relationship-list">
        {outgoing.map((r) => (
          <li>
            <span class="rel-type">{tRelationshipType(lang, r.relationshipType)}</span>
            <a href={`/assets/${r.relatedAsset.slug}`}>{r.relatedAsset.name}</a>
            <span style="color:var(--bs-muted); font-size:0.85rem;">({tAssetType(lang, r.relatedAsset.type)})</span>
          </li>
        ))}
      </ul>

      <h3>{t(lang, "asset.incoming")}</h3>
      {incoming.length === 0 && <p class="no-changes">{t(lang, "asset.noIncoming")}</p>}
      <ul class="relationship-list">
        {incoming.map((r) => (
          <li>
            <a href={`/assets/${r.sourceAsset.slug}`}>{r.sourceAsset.name}</a>
            <span class="rel-type">{tRelationshipType(lang, r.relationshipType)}</span>
            <span style="color:var(--bs-muted); font-size:0.85rem;">{t(lang, "asset.thisAsset")}</span>
          </li>
        ))}
      </ul>

      {
        Astro.locals.user && otherAssets.length > 0 && (
          <form class="relate-form" method="POST" action={actions.addAssetRelationship}>
            <input type="hidden" name="assetSlug" value={asset.slug} />
            <select name="relationshipType" required>
              {relationshipTypes.map((rt) => (
                <option value={rt}>{tRelationshipType(lang, rt)}</option>
              ))}
            </select>
            <select name="relatedAssetSlug" required>
              {otherAssets.map((a) => (
                <option value={a.slug}>{a.name} ({tAssetType(lang, a.type)})</option>
              ))}
            </select>
            <button type="submit" class="secondary-button">{t(lang, "asset.addRelationship")}</button>
          </form>
        )
      }

      {credentialResult?.error && <p class="login-error">{credentialResult.error.message}</p>}
      <CredentialsPanel assetSlug={asset.slug} items={credentialItems} canEdit={!!Astro.locals.user} />
    </main>

    <aside class="bs-side details-side">
      <DetailsPanel
        revision={asset.currentRevision}
        createdBy={asset.createdByName}
        createdAgo={formatRelativeTime(asset.createdAt, lang)}
        updatedBy={asset.updatedByName}
        updatedAgo={formatRelativeTime(asset.updatedAt, lang)}
        revisionsHref={`/assets/${asset.slug}/revisions`}
        editHref={Astro.locals.user ? `/assets/${asset.slug}/edit` : undefined}
        exportData={asset.fields}
        exportFilename={asset.slug}
        exportTitle={asset.name}
      />
      {
        Astro.locals.user && asset.status === "active" && (
          <form method="POST" action={actions.decommissionAsset} style="margin-top:1rem;">
            <input type="hidden" name="slug" value={asset.slug} />
            <button type="submit" class="secondary-button">{t(lang, "asset.decommissionButton")}</button>
          </form>
        )
      }
    </aside>
  </div>
</BookStackLayout>
