---
import BookStackLayout from "../../../layouts/BookStackLayout.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import DetailRowsEditor from "../../../components/DetailRowsEditor.astro";
import { actions } from "astro:actions";
import { getAssetBySlug } from "../../../lib/assetQueries";
import { t } from "../../../lib/i18n";

const lang = Astro.locals.lang;

if (!Astro.locals.user) {
  return Astro.redirect("/login");
}

const { slug } = Astro.params;
const asset = slug ? await getAssetBySlug(slug) : null;

if (!asset) {
  Astro.response.status = 404;
  return Astro.rewrite("/404");
}

const result = Astro.getActionResult(actions.updateAsset);

if (result && !result.error) {
  return Astro.redirect(`/assets/${result.data.slug}`);
}

const backHref = `/assets/${asset.slug}`;

const breadcrumbItems = [
  { label: t(lang, "nav.shelves"), href: "/", icon: "shelf" },
  { label: t(lang, "asset.title"), href: "/assets", icon: "book" },
  { label: asset.name, href: backHref, icon: "page" },
  { label: t(lang, "details.edit"), href: "", icon: "page", current: true },
];
---

<BookStackLayout title={`Edit — ${asset.name}`}>
  <Breadcrumb items={breadcrumbItems} />
  <div class="home-wrap">
    <h1>{t(lang, "asset.editTitle")}</h1>
    {result?.error && <p class="login-error">{result.error.message}</p>}

    <form class="page-form" method="POST" action={actions.updateAsset}>
      <input type="hidden" name="slug" value={asset.slug} />

      <label>
        {t(lang, "asset.name")}
        <input type="text" name="name" required value={asset.name} />
      </label>

      <label>{t(lang, "asset.fields")}</label>
      <DetailRowsEditor initialDetails={asset.fields} fieldName="fields" />

      <label>
        {t(lang, "asset.editSummary")} <span style="font-weight:400;color:var(--bs-muted);">{t(lang, "asset.editSummaryHint")}</span>
        <input type="text" name="summary" placeholder={t(lang, "asset.editSummaryPlaceholder")} />
      </label>

      <div class="form-actions">
        <button type="submit" class="primary-button">{t(lang, "asset.saveChanges")}</button>
        <a href={backHref} class="secondary-button">{t(lang, "asset.cancel")}</a>
      </div>
    </form>
  </div>
</BookStackLayout>
