---
import BookStackLayout from "../../layouts/BookStackLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import DetailRowsEditor from "../../components/DetailRowsEditor.astro";
import { actions } from "astro:actions";
import { assetTypes } from "../../db/schema";
import { t, tAssetType } from "../../lib/i18n";

const lang = Astro.locals.lang;

if (!Astro.locals.user) {
  return Astro.redirect("/login");
}

const result = Astro.getActionResult(actions.createAsset);

if (result && !result.error) {
  return Astro.redirect(`/assets/${result.data.slug}`);
}

const breadcrumbItems = [
  { label: t(lang, "nav.shelves"), href: "/", icon: "shelf" },
  { label: t(lang, "asset.title"), href: "/assets", icon: "book" },
  { label: t(lang, "asset.newTitle"), href: "", icon: "page", current: true },
];
---

<BookStackLayout title="New Asset">
  <Breadcrumb items={breadcrumbItems} />
  <div class="home-wrap">
    <h1>{t(lang, "asset.newTitle")}</h1>
    {result?.error && <p class="login-error">{result.error.message}</p>}

    <form class="page-form" method="POST" action={actions.createAsset}>
      <label>
        {t(lang, "asset.type")}
        <select name="type" required>
          {assetTypes.map((type) => (
            <option value={type}>{tAssetType(lang, type)}</option>
          ))}
        </select>
      </label>

      <label>
        {t(lang, "asset.name")}
        <input type="text" name="name" required placeholder="e.g. prod-azure-thornwake" />
      </label>

      <label>{t(lang, "asset.fields")}</label>
      <DetailRowsEditor fieldName="fields" />

      <div class="form-actions">
        <button type="submit" class="primary-button">{t(lang, "asset.create")}</button>
        <a href="/assets" class="secondary-button">{t(lang, "asset.cancel")}</a>
      </div>
    </form>
  </div>
</BookStackLayout>
