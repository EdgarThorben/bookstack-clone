---
import BookStackLayout from "../../layouts/BookStackLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { listAssets } from "../../lib/assetQueries";
import { t, tAssetType } from "../../lib/i18n";

const lang = Astro.locals.lang;
const allAssets = await listAssets();

const groups = new Map<string, typeof allAssets>();
for (const asset of allAssets) {
  if (!groups.has(asset.type)) groups.set(asset.type, []);
  groups.get(asset.type)!.push(asset);
}

const breadcrumbItems = [
  { label: t(lang, "nav.shelves"), href: "/", icon: "shelf" },
  { label: t(lang, "asset.title"), href: "", icon: "book", current: true },
];
---

<BookStackLayout title="Assets">
  <Breadcrumb items={breadcrumbItems} />
  <div class="home-wrap">
    <h1>{t(lang, "asset.title")}</h1>
    <p style="color:var(--bs-muted); max-width:60ch; margin-bottom:2rem;">
      {t(lang, "asset.tagline")}
    </p>

    {Astro.locals.user && <a class="new-page-link" href="/assets/new">{t(lang, "asset.new")}</a>}

    {allAssets.length === 0 && <p class="no-changes">{t(lang, "asset.none")}</p>}

    {
      [...groups.entries()].map(([type, items]) => (
        <>
          <div class="shelf-block-header" style="margin-top:2rem;">
            <h2>{tAssetType(lang, type)}</h2>
            <p>{items.length} {items.length === 1 ? t(lang, "asset.asset") : t(lang, "asset.assets")}</p>
          </div>
          <div class="card-grid">
            {items.map((asset) => (
              <a class="book-card" href={`/assets/${asset.slug}`}>
                <span class="card-title" style="padding-top:1rem;">
                  {asset.name}
                  {asset.status === "decommissioned" && (
                    <span class="asset-status-badge">{t(lang, "asset.decommissioned")}</span>
                  )}
                </span>
              </a>
            ))}
          </div>
        </>
      ))
    }
  </div>
</BookStackLayout>
