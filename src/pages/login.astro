---
import BookStackLayout from "../layouts/BookStackLayout.astro";
import { actions } from "astro:actions";
import { t } from "../lib/i18n";

const lang = Astro.locals.lang;

const loginResult = Astro.getActionResult(actions.login);
const demoResult = Astro.getActionResult(actions.demoLogin);
const result = loginResult ?? demoResult;

if (result && !result.error) {
  return Astro.redirect("/");
}
---

<BookStackLayout title="Log in">
  <div class="login-wrap">
    <div class="login-card">
      <h1>{t(lang, "login.title")}</h1>

      <form method="POST" action={actions.demoLogin}>
        <button type="submit" class="primary-button demo-login-button">{t(lang, "login.demoButton")}</button>
      </form>

      <div class="login-divider"><span>{t(lang, "login.divider")}</span></div>

      <p class="login-note">
        {t(lang, "login.note")}
        <code>NimbusDemo!2024</code> — try <code>priya@nimbusvault.io</code>,
        <code>barry@nimbusvault.io</code>, or <code>marcus@nimbusvault.io</code>.
      </p>
      {
        result?.error && (
          <p class="login-error">{result.error.message}</p>
        )
      }
      <form class="login-form" method="POST" action={actions.login}>
        <label>
          {t(lang, "login.email")}
          <input type="email" name="email" placeholder="you@nimbusvault.io" required />
        </label>
        <label>
          {t(lang, "login.password")}
          <input type="password" name="password" placeholder="••••••••" required />
        </label>
        <button type="submit">{t(lang, "login.submit")}</button>
      </form>
      <a class="back-link" href="/">{t(lang, "login.backLink")}</a>
    </div>
  </div>
</BookStackLayout>
