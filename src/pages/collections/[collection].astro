---
import BookStackLayout from "../../layouts/BookStackLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { getCollectionBySlug } from "../../lib/itemQueries";
import { t, tItemType } from "../../lib/i18n";

const lang = Astro.locals.lang;
const { collection: collectionSlug } = Astro.params;
const collection = collectionSlug ? await getCollectionBySlug(collectionSlug) : null;

if (!collection) {
  Astro.response.status = 404;
  return Astro.rewrite("/404");
}

const sections = new Map<string, typeof collection.items>();
for (const item of collection.items) {
  const key = item.section ?? "";
  if (!sections.has(key)) sections.set(key, []);
  sections.get(key)!.push(item);
}

const breadcrumbItems = [
  { label: t(lang, "nav.home"), href: "/", icon: "shelf" },
  { label: collection.title, href: "", icon: "book", current: true },
];
---

<BookStackLayout title={collection.title}>
  <Breadcrumb items={breadcrumbItems} />
  <div class="home-wrap">
    <img class="simple-page-hero" src={collection.imageUrl} alt={collection.title} />
    <h1>{collection.title}</h1>
    <p style="color:var(--bs-muted); max-width:60ch; margin-bottom:1rem;">{collection.description}</p>

    {
      Astro.locals.user && (
        <a class="new-page-link" href={`/items/new?collection=${collection.slug}`}>{t(lang, "item.new")}</a>
      )
    }

    <div class="shelf-block-header">
      <h2>{t(lang, "collection.itemsInCollection")}</h2>
      <p>{collection.items.length} {collection.items.length === 1 ? t(lang, "collection.item") : t(lang, "collection.items")}</p>
    </div>

    {collection.items.length === 0 && <p class="no-changes">{t(lang, "item.none")}</p>}

    {
      [...sections.entries()].map(([section, items]) => (
        <details class="category-details" open>
          <summary>
            {section || t(lang, "collection.section.other")} <span class="cat-count">({items.length})</span>
          </summary>
          <table class="detail-table">
            <tbody>
              {items.map((item) => (
                <tr>
                  <td><a href={`/items/${item.slug}`}>{item.name}</a></td>
                  <td class="badge-cell">
                    <span class="badge badge--neutral">{tItemType(lang, item.type)}</span>
                    {item.status === "archived" && <span class="badge badge--warning">{t(lang, "item.archived")}</span>}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </details>
      ))
    }
  </div>
</BookStackLayout>
