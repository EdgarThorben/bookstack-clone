---
import BookStackLayout from "../../layouts/BookStackLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { actions } from "astro:actions";
import { t } from "../../lib/i18n";

const lang = Astro.locals.lang;

if (!Astro.locals.user) {
  return Astro.redirect("/login");
}

const result = Astro.getActionResult(actions.createCollection);

if (result && !result.error) {
  return Astro.redirect(`/collections/${result.data.slug}`);
}

const breadcrumbItems = [
  { label: t(lang, "nav.home"), href: "/", icon: "shelf" },
  { label: t(lang, "collection.newTitle"), href: "", icon: "page", current: true },
];
---

<BookStackLayout title="New Collection">
  <Breadcrumb items={breadcrumbItems} />
  <div class="home-wrap">
    <h1>{t(lang, "collection.newTitle")}</h1>
    {result?.error && <p class="login-error">{result.error.message}</p>}

    <form class="page-form" method="POST" action={actions.createCollection}>
      <label>
        {t(lang, "collection.name")}
        <input type="text" name="title" required placeholder="e.g. Acme Corp (Berlin)" />
      </label>

      <label>
        {t(lang, "collection.category")}
        <select name="category" required>
          <option value="Clients">{t(lang, "collection.categoryClients")}</option>
          <option value="Internal">{t(lang, "collection.categoryInternal")}</option>
        </select>
      </label>

      <label>
        {t(lang, "collection.description")}
        <textarea name="description" required placeholder="What is this collection for?"></textarea>
      </label>

      <label>
        {t(lang, "collection.imageUrl")} <span style="font-weight:400;color:var(--muted);">{t(lang, "collection.imageUrlHint")}</span>
        <input type="url" name="imageUrl" required placeholder="https://..." />
      </label>

      <div class="form-actions">
        <button type="submit" class="primary-button">{t(lang, "collection.create")}</button>
        <a href="/" class="secondary-button">{t(lang, "item.cancel")}</a>
      </div>
    </form>
  </div>
</BookStackLayout>
