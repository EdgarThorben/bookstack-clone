---
import BookStackLayout from "../../../../layouts/BookStackLayout.astro";
import Breadcrumb from "../../../../components/Breadcrumb.astro";
import BookNav from "../../../../components/BookNav.astro";
import DetailsPanel from "../../../../components/DetailsPanel.astro";
import { getBookNav, getPageBySlug } from "../../../../lib/queries";
import { groupDetailsByCategory } from "../../../../lib/details";
import { breadcrumbForPage } from "../../../../lib/breadcrumbs";
import { formatRelativeTime } from "../../../../lib/time";
import { t } from "../../../../lib/i18n";

const lang = Astro.locals.lang;
const { slug } = Astro.params;
const nav = await getBookNav("oberlinhaus");
const server = slug ? await getPageBySlug(slug) : null;

if (!server || server.bookId !== nav.book.id) {
  Astro.response.status = 404;
  return Astro.rewrite("/404");
}

const categories = groupDetailsByCategory(server.details);
---

<BookStackLayout title={server.title}>
  <Breadcrumb
    items={breadcrumbForPage({
      shelvesLabel: t(lang, "nav.shelves"),
      shelfTitle: nav.shelf.title,
      shelfSlug: nav.shelf.slug,
      bookTitle: nav.book.title,
      bookSlug: nav.book.slug,
      chapterTitle: nav.chapter?.title,
      pageTitle: server.title,
    })}
  />
  <div class="bs-layout">
    <aside class="bs-side">
      <h4>{t(lang, "page.pageNav")}</h4>
      <ul class="page-nav-list">
        <li><a href="#system-details" class="active">{t(lang, "page.systemDetails")}</a></li>
        <li><a href="#server-image">{t(lang, "page.serverImage")}</a></li>
      </ul>
      <h4>{t(lang, "page.bookNav")}</h4>
      <BookNav
        bookTitle={nav.book.title}
        bookHref={`/books/${nav.book.slug}`}
        chapterTitle={nav.chapter?.title ?? t(lang, "oberlinhaus.chapterFallback")}
        chapterPages={nav.chapterPages}
        otherPages={nav.otherPages}
        activeSlug={server.slug}
      />
    </aside>

    <main class="bs-content">
      <h1>{server.title}</h1>

      <h2 id="system-details">{t(lang, "page.systemDetails")}</h2>
      {
        categories.map((group) => (
          <details class="category-details" open>
            <summary>
              {group.category} <span class="cat-count">({group.items.length})</span>
            </summary>
            <div class="table-scroll">
              <table class="detail-table">
                <tbody>
                  {group.items.map((d) => (
                    <tr>
                      <th>{d.label}</th>
                      <td>{d.value}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </details>
        ))
      }

      {
        server.warning && (
          <div class="warning-box">
            <span class="warn-icon">&#9888;</span>
            <div>{server.warning}</div>
          </div>
        )
      }

      <h2 id="server-image">{t(lang, "page.serverImage")}</h2>
      <img class="server-image" src={server.imageUrl ?? undefined} alt={`Photo for ${server.title}`} />
    </main>

    <aside class="bs-side details-side">
      <DetailsPanel
        revision={server.currentRevision}
        createdBy={server.createdByName}
        createdAgo={formatRelativeTime(server.createdAt, lang)}
        updatedBy={server.updatedByName}
        updatedAgo={formatRelativeTime(server.updatedAt, lang)}
        revisionsHref={`/books/oberlinhaus/page/${server.slug}/revisions`}
        exportData={server.details}
        exportFilename={server.slug}
        exportTitle={server.title}
      />
    </aside>
  </div>
</BookStackLayout>
