---
import BookStackLayout from "../../../layouts/BookStackLayout.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import { getBookNav } from "../../../lib/queries";

const { book, shelf, chapter, chapterPages, otherPages } = await getBookNav("oberlinhaus");

const breadcrumbItems = [
  { label: "Shelves", href: "/", icon: "shelf" },
  { label: shelf.title, href: `/shelves/${shelf.slug}`, icon: "shelf" },
  { label: book.title, href: "", icon: "book", current: true },
];
---

<BookStackLayout title={book.title}>
  <Breadcrumb items={breadcrumbItems} />
  <div class="home-wrap">
    <h1>{book.title}</h1>
    <p style="color:var(--bs-muted); max-width:60ch; margin-bottom:2rem;">
      {book.description}
    </p>

    <div class="shelf-block-header">
      <h2>&#9656; {chapter?.title ?? "Server & Systeme"}</h2>
      <p>{chapterPages.length} pages</p>
    </div>
    <div class="card-grid">
      {
        chapterPages.map((s) => (
          <a class="book-card" href={`/books/oberlinhaus/page/${s.slug}`}>
            <img class="cover-image" src={s.imageUrl ?? undefined} alt={s.title} />
            <span class="card-title">{s.title}</span>
            <p>{s.region}</p>
          </a>
        ))
      }
    </div>

    {
      otherPages.length > 0 && (
        <>
          <div class="shelf-block-header" style="margin-top:2.5rem;">
            <h2>Other Pages</h2>
          </div>
          <div class="card-grid">
            {otherPages.map((p) => (
              <a class="book-card" href={`/books/oberlinhaus/page/${p.slug}`}>
                <span class="card-title" style="padding-top:1rem;">{p.title}</span>
              </a>
            ))}
          </div>
        </>
      )
    }
  </div>
</BookStackLayout>
