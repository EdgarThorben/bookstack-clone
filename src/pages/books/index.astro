---
import BookStackLayout from "../../layouts/BookStackLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { getAllBooksWithShelf } from "../../lib/queries";
import { t } from "../../lib/i18n";

const lang = Astro.locals.lang;

const breadcrumbItems = [
  { label: t(lang, "nav.shelves"), href: "/", icon: "shelf" },
  { label: t(lang, "books.title"), href: "", icon: "book", current: true },
];

const allBooks = await getAllBooksWithShelf();
---

<BookStackLayout title="All Books">
  <Breadcrumb items={breadcrumbItems} />
  <div class="home-wrap">
    <h1>{t(lang, "books.title")}</h1>
    <p style="color:var(--bs-muted); max-width:60ch; margin-bottom:2rem;">
      {t(lang, "books.tagline")}
    </p>
    <div class="card-grid">
      {
        allBooks.map((book) => (
          <a class="book-card" href={`/books/${book.slug}`}>
            <img class="cover-image" src={book.imageUrl} alt={`${book.title} cover`} />
            <span class="card-title">{book.title}</span>
            <p>{book.description}</p>
            <div class="card-meta">&#128214; {book.pageCount} {t(lang, "books.pages")} &middot; {book.shelfTitle}</div>
          </a>
        ))
      }
    </div>
  </div>
</BookStackLayout>
