---
import BookStackLayout from "../../../../layouts/BookStackLayout.astro";
import Breadcrumb from "../../../../components/Breadcrumb.astro";
import DetailRowsEditor from "../../../../components/DetailRowsEditor.astro";
import { actions } from "astro:actions";
import { getItDepartmentNav } from "../../../../lib/queries";
import { t } from "../../../../lib/i18n";

const lang = Astro.locals.lang;

if (!Astro.locals.user) {
  return Astro.redirect("/login");
}

const nav = await getItDepartmentNav();
const result = Astro.getActionResult(actions.createPage);

if (result && !result.error) {
  return Astro.redirect(`/books/it-department/page/${result.data.slug}`);
}

const breadcrumbItems = [
  { label: t(lang, "nav.shelves"), href: "/", icon: "shelf" },
  { label: t(lang, "itDept.breadcrumbShelf"), href: "/shelves/internal-departments", icon: "shelf" },
  { label: t(lang, "itDept.title"), href: "/books/it-department", icon: "book" },
  { label: t(lang, "page.newTitle"), href: "", icon: "page", current: true },
];
---

<BookStackLayout title="New Page">
  <Breadcrumb items={breadcrumbItems} />
  <div class="home-wrap">
    <h1>{t(lang, "page.newTitle")}</h1>
    {result?.error && <p class="login-error">{result.error.message}</p>}

    <form class="page-form" method="POST" action={actions.createPage}>
      <label>
        {t(lang, "page.pageTitle")}
        <input type="text" name="title" required placeholder="e.g. prod-aws-newnode" />
      </label>

      <fieldset>
        <legend>{t(lang, "page.placement")}</legend>
        <label>
          <input type="radio" name="chapter" value="server-systems" checked />
          {nav.chapter?.title ?? t(lang, "itDept.chapterFallback")} {t(lang, "page.placementChapter")}
        </label>
        <label>
          <input type="radio" name="chapter" value="other" />
          {t(lang, "page.placementStandalone")}
        </label>
      </fieldset>

      <label>
        {t(lang, "page.region")} <span style="font-weight:400;color:var(--bs-muted);">{t(lang, "page.regionHint")}</span>
        <input type="text" name="region" placeholder="e.g. AWS us-east-1" />
      </label>

      <label>
        {t(lang, "page.imageUrl")} <span style="font-weight:400;color:var(--bs-muted);">{t(lang, "page.imageUrlHint")}</span>
        <input type="url" name="imageUrl" placeholder="https://..." />
      </label>

      <label>
        {t(lang, "page.warning")} <span style="font-weight:400;color:var(--bs-muted);">{t(lang, "page.warningHint")}</span>
        <textarea name="warning" placeholder="e.g. Do not restart this machine..."></textarea>
      </label>

      <label>{t(lang, "page.systemDetails")}</label>
      <DetailRowsEditor />

      <div class="form-actions">
        <button type="submit" class="primary-button">{t(lang, "page.create")}</button>
        <a href="/books/it-department" class="secondary-button">{t(lang, "asset.cancel")}</a>
      </div>
    </form>
  </div>
</BookStackLayout>
