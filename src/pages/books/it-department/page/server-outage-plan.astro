---
import BookStackLayout from "../../../../layouts/BookStackLayout.astro";
import Breadcrumb from "../../../../components/Breadcrumb.astro";
import BookNav from "../../../../components/BookNav.astro";
import DetailsPanel from "../../../../components/DetailsPanel.astro";
import { getItDepartmentNav, getPageBySlug } from "../../../../lib/queries";
import { breadcrumbForPage } from "../../../../lib/breadcrumbs";
import { formatRelativeTime } from "../../../../lib/time";
import { t } from "../../../../lib/i18n";

const lang = Astro.locals.lang;
const nav = await getItDepartmentNav();
const page = await getPageBySlug("server-outage-plan");

if (!page) {
  Astro.response.status = 404;
  return Astro.rewrite("/404");
}

const escalation: Record<string, string> = {
  "SEV-1": t(lang, "outagePlan.escalationSev1"),
  "SEV-2": t(lang, "outagePlan.escalationSev2"),
  "SEV-3": t(lang, "outagePlan.escalationSev3"),
  "SEV-4": t(lang, "outagePlan.escalationSev4"),
};
---

<BookStackLayout title="Server Outage Plan">
  <Breadcrumb
    items={breadcrumbForPage({
      shelvesLabel: t(lang, "nav.shelves"),
      shelfTitle: nav.shelf.title,
      shelfSlug: nav.shelf.slug,
      bookTitle: nav.book.title,
      bookSlug: nav.book.slug,
      pageTitle: t(lang, "outagePlan.title"),
    })}
  />
  <div class="bs-layout">
    <aside class="bs-side">
      <h4>{t(lang, "page.pageNav")}</h4>
      <ul class="page-nav-list">
        <li><a href="#severity-levels" class="active">{t(lang, "outagePlan.navSeverity")}</a></li>
        <li><a href="#response-steps">{t(lang, "outagePlan.navResponse")}</a></li>
      </ul>
      <h4>{t(lang, "page.bookNav")}</h4>
      <BookNav
        bookTitle={nav.book.title}
        bookHref={`/books/${nav.book.slug}`}
        chapterTitle={nav.chapter?.title ?? t(lang, "itDept.chapterFallback")}
        chapterPages={nav.chapterPages}
        otherPages={nav.otherPages}
        activeSlug="server-outage-plan"
      />
    </aside>

    <main class="bs-content">
      <h1>{t(lang, "outagePlan.title")}</h1>
      <p>{t(lang, "outagePlan.intro")}</p>

      <div class="warning-box">
        <span class="warn-icon">&#9888;</span>
        <div>{t(lang, "outagePlan.warning")}</div>
      </div>

      <h2 id="severity-levels">{t(lang, "outagePlan.severityLevels")}</h2>
      <div class="table-scroll">
        <table class="detail-table">
          <thead>
            <tr>
              <th>{t(lang, "outagePlan.severity")}</th>
              <th>{t(lang, "outagePlan.description")}</th>
              <th>{t(lang, "outagePlan.escalation")}</th>
            </tr>
          </thead>
          <tbody>
            {
              page.details.map((d) => (
                <tr>
                  <td>{d.label}</td>
                  <td>{d.value}</td>
                  <td>{escalation[d.label] ?? "—"}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>

      <h2 id="response-steps">{t(lang, "outagePlan.responseSteps")}</h2>
      <ol>
        <li>{t(lang, "outagePlan.step1")}</li>
        <li>{t(lang, "outagePlan.step2")}</li>
        <li>{t(lang, "outagePlan.step3")}</li>
        <li>{t(lang, "outagePlan.step4")}</li>
        <li>{t(lang, "outagePlan.step5")}</li>
      </ol>
    </main>

    <aside class="bs-side details-side">
      <DetailsPanel
        revision={page.currentRevision}
        createdBy={page.createdByName}
        createdAgo={formatRelativeTime(page.createdAt, lang)}
        updatedBy={page.updatedByName}
        updatedAgo={formatRelativeTime(page.updatedAt, lang)}
        revisionsHref={`/books/it-department/page/${page.slug}/revisions`}
        editHref={Astro.locals.user ? `/books/it-department/page/${page.slug}/edit` : undefined}
        exportData={page.details}
        exportFilename={page.slug}
        exportTitle={page.title}
      />
    </aside>
  </div>
</BookStackLayout>
