---
import BookStackLayout from "../../../../layouts/BookStackLayout.astro";
import Breadcrumb from "../../../../components/Breadcrumb.astro";
import BookNav from "../../../../components/BookNav.astro";
import DetailsPanel from "../../../../components/DetailsPanel.astro";
import { getItDepartmentNav, getPageBySlug } from "../../../../lib/queries";
import { breadcrumbForPage } from "../../../../lib/breadcrumbs";
import { formatRelativeTime } from "../../../../lib/time";
import { t } from "../../../../lib/i18n";

const lang = Astro.locals.lang;
const nav = await getItDepartmentNav();
const page = await getPageBySlug("it-holiday-party-event");

if (!page) {
  Astro.response.status = 404;
  return Astro.rewrite("/404");
}

const schedule = [
  { time: t(lang, "holidayParty.time1"), activity: t(lang, "holidayParty.activity1") },
  { time: t(lang, "holidayParty.time2"), activity: t(lang, "holidayParty.activity2") },
  { time: t(lang, "holidayParty.time3"), activity: t(lang, "holidayParty.activity3") },
  { time: t(lang, "holidayParty.time4"), activity: t(lang, "holidayParty.activity4") },
  { time: t(lang, "holidayParty.time5"), activity: t(lang, "holidayParty.activity5") },
];
---

<BookStackLayout title="IT Holiday Party Event">
  <Breadcrumb
    items={breadcrumbForPage({
      shelvesLabel: t(lang, "nav.shelves"),
      shelfTitle: nav.shelf.title,
      shelfSlug: nav.shelf.slug,
      bookTitle: nav.book.title,
      bookSlug: nav.book.slug,
      pageTitle: t(lang, "holidayParty.title"),
    })}
  />
  <div class="bs-layout">
    <aside class="bs-side">
      <h4>{t(lang, "page.pageNav")}</h4>
      <ul class="page-nav-list">
        <li><a href="#details" class="active">{t(lang, "holidayParty.details")}</a></li>
        <li><a href="#schedule">{t(lang, "holidayParty.schedule")}</a></li>
      </ul>
      <h4>{t(lang, "page.bookNav")}</h4>
      <BookNav
        bookTitle={nav.book.title}
        bookHref={`/books/${nav.book.slug}`}
        chapterTitle={nav.chapter?.title ?? t(lang, "itDept.chapterFallback")}
        chapterPages={nav.chapterPages}
        otherPages={nav.otherPages}
        activeSlug="it-holiday-party-event"
      />
    </aside>

    <main class="bs-content">
      <h1>{t(lang, "holidayParty.title")}</h1>
      <img
        class="simple-page-hero"
        src="https://picsum.photos/seed/nimbusvault-holiday-party/1000/500"
        alt="Holiday party celebration"
      />

      <h2 id="details">{t(lang, "holidayParty.details")}</h2>
      <table class="detail-table">
        <tbody>
          {
            page.details.map((d) => (
              <tr>
                <th>{d.label}</th>
                <td>{d.value}</td>
              </tr>
            ))
          }
        </tbody>
      </table>

      <h2 id="schedule">{t(lang, "holidayParty.schedule")}</h2>
      <div class="table-scroll">
        <table class="detail-table">
          <thead>
            <tr><th>{t(lang, "holidayParty.time")}</th><th>{t(lang, "holidayParty.activity")}</th></tr>
          </thead>
          <tbody>
            {
              schedule.map((s) => (
                <tr>
                  <td>{s.time}</td>
                  <td>{s.activity}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </main>

    <aside class="bs-side details-side">
      <DetailsPanel
        revision={page.currentRevision}
        createdBy={page.createdByName}
        createdAgo={formatRelativeTime(page.createdAt, lang)}
        updatedBy={page.updatedByName}
        updatedAgo={formatRelativeTime(page.updatedAt, lang)}
        revisionsHref={`/books/it-department/page/${page.slug}/revisions`}
        editHref={Astro.locals.user ? `/books/it-department/page/${page.slug}/edit` : undefined}
        exportData={page.details}
        exportFilename={page.slug}
        exportTitle={page.title}
      />
    </aside>
  </div>
</BookStackLayout>
