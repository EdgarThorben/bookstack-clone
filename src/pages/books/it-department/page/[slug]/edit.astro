---
import BookStackLayout from "../../../../../layouts/BookStackLayout.astro";
import Breadcrumb from "../../../../../components/Breadcrumb.astro";
import DetailRowsEditor from "../../../../../components/DetailRowsEditor.astro";
import { actions } from "astro:actions";
import { getPageBySlug } from "../../../../../lib/queries";
import { t } from "../../../../../lib/i18n";

const lang = Astro.locals.lang;

if (!Astro.locals.user) {
  return Astro.redirect("/login");
}

const { slug } = Astro.params;
const page = slug ? await getPageBySlug(slug) : null;

if (!page) {
  Astro.response.status = 404;
  return Astro.rewrite("/404");
}

const result = Astro.getActionResult(actions.updatePage);

if (result && !result.error) {
  return Astro.redirect(`/books/it-department/page/${result.data.slug}`);
}

const backHref = `/books/it-department/page/${page.slug}`;

const breadcrumbItems = [
  { label: t(lang, "nav.shelves"), href: "/", icon: "shelf" },
  { label: t(lang, "itDept.title"), href: "/books/it-department", icon: "book" },
  { label: page.title, href: backHref, icon: "page" },
  { label: t(lang, "details.edit"), href: "", icon: "page", current: true },
];
---

<BookStackLayout title={`Edit — ${page.title}`}>
  <Breadcrumb items={breadcrumbItems} />
  <div class="home-wrap">
    <h1>{t(lang, "page.editTitle")}</h1>
    {result?.error && <p class="login-error">{result.error.message}</p>}

    <form class="page-form" method="POST" action={actions.updatePage}>
      <input type="hidden" name="slug" value={page.slug} />

      <label>
        {t(lang, "page.pageTitle")}
        <input type="text" name="title" required value={page.title} />
      </label>

      <label>
        {t(lang, "page.region")} <span style="font-weight:400;color:var(--bs-muted);">{t(lang, "page.regionHint")}</span>
        <input type="text" name="region" value={page.region ?? ""} />
      </label>

      <label>
        {t(lang, "page.imageUrl")} <span style="font-weight:400;color:var(--bs-muted);">{t(lang, "page.imageUrlHint")}</span>
        <input type="url" name="imageUrl" value={page.imageUrl ?? ""} />
      </label>

      <label>
        {t(lang, "page.warning")} <span style="font-weight:400;color:var(--bs-muted);">{t(lang, "page.warningHint")}</span>
        <textarea name="warning">{page.warning ?? ""}</textarea>
      </label>

      <label>{t(lang, "page.systemDetails")}</label>
      <DetailRowsEditor initialDetails={page.details} />

      <label>
        {t(lang, "asset.editSummary")} <span style="font-weight:400;color:var(--bs-muted);">{t(lang, "asset.editSummaryHint")}</span>
        <input type="text" name="summary" placeholder={t(lang, "asset.editSummaryPlaceholder")} />
      </label>

      <div class="form-actions">
        <button type="submit" class="primary-button">{t(lang, "asset.saveChanges")}</button>
        <a href={backHref} class="secondary-button">{t(lang, "asset.cancel")}</a>
      </div>
    </form>
  </div>
</BookStackLayout>
