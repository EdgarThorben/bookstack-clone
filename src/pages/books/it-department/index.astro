---
import BookStackLayout from "../../../layouts/BookStackLayout.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import { getItDepartmentNav } from "../../../lib/queries";
import { t } from "../../../lib/i18n";

const lang = Astro.locals.lang;
const { chapter, chapterPages, otherPages } = await getItDepartmentNav();

const breadcrumbItems = [
  { label: t(lang, "nav.shelves"), href: "/", icon: "shelf" },
  { label: t(lang, "itDept.breadcrumbShelf"), href: "/shelves/internal-departments", icon: "shelf" },
  { label: t(lang, "itDept.title"), href: "", icon: "book", current: true },
];
---

<BookStackLayout title="IT Department">
  <Breadcrumb items={breadcrumbItems} />
  <div class="home-wrap">
    <h1>{t(lang, "itDept.title")}</h1>
    <p style="color:var(--bs-muted); max-width:60ch; margin-bottom:2rem;">
      {t(lang, "itDept.tagline")}
    </p>

    {Astro.locals.user && <a class="new-page-link" href="/books/it-department/page/new">{t(lang, "book.newPage")}</a>}

    <div class="shelf-block-header">
      <h2>&#9656; {chapter?.title ?? t(lang, "itDept.chapterFallback")}</h2>
      <p>{chapterPages.length} {t(lang, "book.pages")}</p>
    </div>
    <div class="card-grid">
      {
        chapterPages.map((s) => (
          <a class="book-card" href={`/books/it-department/page/${s.slug}`}>
            <img class="cover-image" src={s.imageUrl ?? undefined} alt={s.title} />
            <span class="card-title">{s.title}</span>
            <p>{s.region}</p>
          </a>
        ))
      }
    </div>

    <div class="shelf-block-header" style="margin-top:2.5rem;">
      <h2>{t(lang, "book.otherPages")}</h2>
    </div>
    <div class="card-grid">
      {
        otherPages.map((p) => (
          <a class="book-card" href={`/books/it-department/page/${p.slug}`}>
            <span class="card-title" style="padding-top:1rem;">{p.title}</span>
          </a>
        ))
      }
    </div>
  </div>
</BookStackLayout>
