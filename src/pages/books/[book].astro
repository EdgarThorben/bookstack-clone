---
import BookStackLayout from "../../layouts/BookStackLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { getBookWithShelfBySlug } from "../../lib/queries";

const { book: bookSlug } = Astro.params;

if (bookSlug === "it-department") {
  return Astro.redirect("/books/it-department");
}

const result = bookSlug ? await getBookWithShelfBySlug(bookSlug) : null;

if (!result) {
  Astro.response.status = 404;
  return Astro.rewrite("/404");
}

const { book, shelf } = result;

const chapterNames = ["Getting Started", "Reference"];
const firstHalf = Math.ceil(book.pageCount / 2);
const chapters = chapterNames.map((name, i) => {
  const count = i === 0 ? firstHalf : book.pageCount - firstHalf;
  return {
    name,
    pages: Array.from({ length: Math.max(count, 1) }, (_, j) => `${name.replace(/s$/, "")} Guide ${j + 1}`),
  };
});

const breadcrumbItems = [
  { label: "Shelves", href: "/", icon: "shelf" },
  { label: shelf.title, href: `/shelves/${shelf.slug}`, icon: "shelf" },
  { label: book.title, href: "", icon: "book", current: true },
];
---

<BookStackLayout title={book.title}>
  <Breadcrumb items={breadcrumbItems} />
  <div class="home-wrap">
    <img class="simple-page-hero" src={book.imageUrl} alt={book.title} />
    <h1>{book.title}</h1>
    <p style="color:var(--bs-muted); max-width:60ch; margin-bottom:2rem;">{book.description}</p>

    <div class="shelf-block-header">
      <h2>Chapters</h2>
      <p>{book.pageCount} pages across {chapters.length} chapters</p>
    </div>

    {
      chapters.map((ch) => (
        <details class="category-details" open>
          <summary>
            {ch.name} <span class="cat-count">({ch.pages.length} pages)</span>
          </summary>
          <table class="detail-table">
            <tbody>
              {ch.pages.map((p) => (
                <tr>
                  <td>{p}</td>
                  <td class="badge-cell">
                    <span class="badge-soon">Coming soon</span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </details>
      ))
    }
  </div>
</BookStackLayout>
