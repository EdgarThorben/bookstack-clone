---
import BookStackLayout from "../../layouts/BookStackLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { getShelfBySlug } from "../../lib/queries";
import { t } from "../../lib/i18n";

const lang = Astro.locals.lang;

const { shelf: shelfSlug } = Astro.params;
const shelf = shelfSlug ? await getShelfBySlug(shelfSlug) : null;

if (!shelf) {
  Astro.response.status = 404;
  return Astro.rewrite("/404");
}

const breadcrumbItems = [
  { label: t(lang, "nav.shelves"), href: "/", icon: "shelf" },
  { label: shelf.title, href: "", icon: "shelf", current: true },
];
---

<BookStackLayout title={shelf.title}>
  <Breadcrumb items={breadcrumbItems} />
  <div class="home-wrap">
    <img class="simple-page-hero" src={shelf.imageUrl} alt={shelf.title} />
    <h1>{shelf.title}</h1>
    <p style="color:var(--bs-muted); max-width:60ch; margin-bottom:2rem;">{shelf.description}</p>

    <div class="shelf-block-header">
      <h2>{t(lang, "shelf.booksOnShelf")}</h2>
      <p>{shelf.books.length} {t(lang, "shelf.books")}</p>
    </div>
    <div class="card-grid">
      {
        shelf.books.map((book) => (
          <a class="book-card" href={`/books/${book.slug}`}>
            <img class="cover-image" src={book.imageUrl} alt={`${book.title} cover`} />
            <span class="card-title">{book.title}</span>
            <p>{book.description}</p>
            <div class="card-meta">&#128214; {book.pageCount} {t(lang, "books.pages")}</div>
          </a>
        ))
      }
    </div>
  </div>
</BookStackLayout>
