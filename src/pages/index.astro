---
import BookStackLayout from "../layouts/BookStackLayout.astro";
import { getShelves, getItDepartmentNav } from "../lib/queries";
import { db } from "../db/client";
import { pages, books } from "../db/schema";
import { eq } from "drizzle-orm";
import { t } from "../lib/i18n";

const lang = Astro.locals.lang;
const shelves = await getShelves();

const itDeptPages = await db
  .select({ details: pages.details })
  .from(pages)
  .innerJoin(books, eq(pages.bookId, books.id))
  .where(eq(books.slug, "it-department"));

const { chapterPages } = await getItDepartmentNav();

const totalStorageTB = itDeptPages.reduce((sum, p) => {
  const detail = p.details.find((d) => d.label === "Customer Data Hosted");
  const match = detail?.value.match(/([\d.]+)TB/);
  return sum + (match ? parseFloat(match[1]) : 0);
}, 0);
---

<BookStackLayout title="Shelves">
  <div class="home-hero">
    <h1>{t(lang, "home.title")}</h1>
    <p>{t(lang, "home.tagline")}</p>
  </div>

  <div class="stat-strip">
    <div class="stat-box">
      <div class="num">{chapterPages.length}</div>
      <div class="lbl">{t(lang, "home.statServers")}</div>
    </div>
    <div class="stat-box">
      <div class="num">{totalStorageTB.toFixed(1)}TB</div>
      <div class="lbl">{t(lang, "home.statStorage")}</div>
    </div>
    <div class="stat-box">
      <div class="num">99.94%</div>
      <div class="lbl">{t(lang, "home.statUptime")}</div>
    </div>
    <div class="stat-box">
      <div class="num">5</div>
      <div class="lbl">{t(lang, "home.statRegions")}</div>
    </div>
  </div>

  <div class="home-wrap">
    {
      shelves.map((shelf) => (
        <div class="shelf-block">
          <div class="shelf-block-header">
            <h2>{shelf.title}</h2>
            <p>{shelf.description}</p>
          </div>
          <div class="card-grid">
            {shelf.books.map((book) => (
              <a class="book-card" href={`/books/${book.slug}`}>
                <img class="cover-image" src={book.imageUrl} alt={`${book.title} cover`} />
                <span class="card-title">{book.title}</span>
                <p>{book.description}</p>
                <div class="card-meta">&#128214; {book.pageCount} {t(lang, "books.pages")}</div>
              </a>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</BookStackLayout>
