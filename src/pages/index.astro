---
import BookStackLayout from "../layouts/BookStackLayout.astro";
import { getCollections, listItems } from "../lib/itemQueries";
import { t } from "../lib/i18n";

const lang = Astro.locals.lang;
const collections = await getCollections();
const allItems = await listItems();

const serverCount = allItems.filter((i) => i.type === "server").length;
const totalStorageTB = allItems.reduce((sum, item) => {
  const field = item.fields.find((f) => f.label === "Customer Data Hosted");
  const match = field?.value.match(/([\d.]+)TB/);
  return sum + (match ? parseFloat(match[1]) : 0);
}, 0);

const totalItems = allItems.length;
const emptyCollections = collections.filter((c) => c.items.length === 0).length;

const groups = new Map<string, typeof collections>();
for (const collection of collections) {
  const key = collection.category ?? "";
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(collection);
}
---

<BookStackLayout title="Home">
  <div class="home-wrap">
    <div class="page-hero">
      <h1>{t(lang, "home.title")}</h1>
      <p class="tagline">{t(lang, "home.tagline")}</p>
      {
        Astro.locals.user && (
          <div class="hero-actions">
            <a class="new-page-link" href="/items/new">{t(lang, "item.new")}</a>
            <a class="new-page-link new-page-link--secondary" href="/collections/new">{t(lang, "collection.new")}</a>
          </div>
        )
      }
    </div>

    <div class="hero-row">
      <div class="health-ring-card">
        <svg width="130" height="130" viewBox="0 0 130 130">
          <circle cx="65" cy="65" r="54" fill="none" stroke="var(--border)" stroke-width="12" />
          <circle
            cx="65" cy="65" r="54" fill="none" stroke="var(--success)" stroke-width="12"
            stroke-linecap="round" stroke-dasharray="339.3" stroke-dashoffset="18"
            transform="rotate(-90 65 65)"
          />
          <text x="65" y="60" text-anchor="middle" style="font-size:1.6rem; font-weight:800; fill:var(--text);">99.94</text>
          <text x="65" y="80" text-anchor="middle" style="font-size:0.62rem; fill:var(--muted); font-weight:700; letter-spacing:0.04em;">% UPTIME</text>
        </svg>
        <div class="ring-label">{t(lang, "home.statUptime")}</div>
      </div>

      <div class="kpi-strip">
        <div class="kpi-card">
          <div class="kpi-top"><span class="kpi-num">{serverCount}</span><span class="kpi-chip good">nominal</span></div>
          <span class="kpi-label">{t(lang, "home.statServers")}</span>
        </div>
        <div class="kpi-card">
          <div class="kpi-top"><span class="kpi-num">{totalStorageTB.toFixed(1)}<span style="font-size:1rem;">TB</span></span><span class="kpi-chip good">encrypted</span></div>
          <span class="kpi-label">{t(lang, "home.statStorage")}</span>
        </div>
        <div class="kpi-card">
          <div class="kpi-top"><span class="kpi-num">5</span></div>
          <span class="kpi-label">{t(lang, "home.statRegions")}</span>
        </div>
        <div class="kpi-card" style="grid-column: 1 / -1;">
          <div class="kpi-top">
            <span class="kpi-num" style="font-size:1.05rem;">{totalItems} {t(lang, "item.items")} {t(lang, "home.acrossCollections")} {collections.length} {collections.length === 1 ? t(lang, "collection.collection") : t(lang, "collection.collections")}</span>
            {emptyCollections > 0 && <span class="kpi-chip warn">{emptyCollections} {t(lang, "home.emptyCollections")}</span>}
          </div>
        </div>
      </div>
    </div>

    {
      [...groups.entries()].map(([category, group]) => (
        <div class="shelf-block">
          {category && (
            <div class="shelf-block-header">
              <h2>{category}</h2>
              <span style="color:var(--muted); font-size:0.78rem;">{group.length} {group.length === 1 ? t(lang, "collection.collection") : t(lang, "collection.collections")}</span>
            </div>
          )}
          <table class="collection-table">
            <thead>
              <tr>
                <th>{t(lang, "item.collection")}</th>
                <th>{t(lang, "home.status")}</th>
                <th style="text-align:right;">{t(lang, "item.items")}</th>
              </tr>
            </thead>
            <tbody>
              {group.map((collection) => (
                <tr>
                  <td>
                    <a class="row-title" href={`/collections/${collection.slug}`}>{collection.title}</a>
                    <div class="row-desc">{collection.description}</div>
                  </td>
                  <td>
                    {collection.items.length > 0 ? (
                      <span class="status-chip status-chip--active"><span class="dot" />{t(lang, "home.active")}</span>
                    ) : (
                      <span class="status-chip status-chip--empty">{t(lang, "home.empty")}</span>
                    )}
                  </td>
                  <td class="count-cell">{collection.items.length}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ))
    }
  </div>
</BookStackLayout>
