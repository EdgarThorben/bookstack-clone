---
import BookStackLayout from "../../layouts/BookStackLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import DetailRowsEditor from "../../components/DetailRowsEditor.astro";
import { actions } from "astro:actions";
import { itemTypes } from "../../db/schema";
import { getCollections } from "../../lib/itemQueries";
import { t, tItemType } from "../../lib/i18n";

const lang = Astro.locals.lang;

if (!Astro.locals.user) {
  return Astro.redirect("/login");
}

const result = Astro.getActionResult(actions.createItem);

if (result && !result.error) {
  return Astro.redirect(`/items/${result.data.slug}`);
}

const collections = await getCollections();
const preselectedCollection = Astro.url.searchParams.get("collection");

const breadcrumbItems = [
  { label: t(lang, "nav.home"), href: "/", icon: "shelf" },
  { label: t(lang, "item.title"), href: "/items", icon: "book" },
  { label: t(lang, "item.newTitle"), href: "", icon: "page", current: true },
];
---

<BookStackLayout title="New Item">
  <Breadcrumb items={breadcrumbItems} />
  <div class="home-wrap">
    <h1>{t(lang, "item.newTitle")}</h1>
    {result?.error && <p class="login-error">{result.error.message}</p>}

    <form class="page-form" method="POST" action={actions.createItem}>
      <label>
        {t(lang, "item.type")}
        <select name="type" required>
          {itemTypes.map((type) => (
            <option value={type}>{tItemType(lang, type)}</option>
          ))}
        </select>
      </label>

      <label>
        {t(lang, "item.collection")}
        <select name="collectionSlug" required>
          {collections.map((c) => (
            <option value={c.slug} selected={c.slug === preselectedCollection}>{c.title}</option>
          ))}
        </select>
      </label>

      <label>
        {t(lang, "item.name")}
        <input type="text" name="name" required placeholder="e.g. prod-azure-thornwake" />
      </label>

      <label>
        {t(lang, "item.section")} <span style="font-weight:400;color:var(--bs-muted);">{t(lang, "item.sectionHint")}</span>
        <input type="text" name="section" placeholder="e.g. Server Systems" />
      </label>

      <label>
        {t(lang, "item.region")} <span style="font-weight:400;color:var(--bs-muted);">{t(lang, "item.regionHint")}</span>
        <input type="text" name="region" placeholder="e.g. AWS us-east-1" />
      </label>

      <label>
        {t(lang, "item.imageUrl")} <span style="font-weight:400;color:var(--bs-muted);">{t(lang, "item.imageUrlHint")}</span>
        <input type="url" name="imageUrl" placeholder="https://..." />
      </label>

      <label>
        {t(lang, "item.warning")} <span style="font-weight:400;color:var(--bs-muted);">{t(lang, "item.warningHint")}</span>
        <textarea name="warning" placeholder="e.g. Do not restart this machine..."></textarea>
      </label>

      <label>{t(lang, "item.fields")}</label>
      <DetailRowsEditor fieldName="fields" />

      <div class="form-actions">
        <button type="submit" class="primary-button">{t(lang, "item.create")}</button>
        <a href="/items" class="secondary-button">{t(lang, "item.cancel")}</a>
      </div>
    </form>
  </div>
</BookStackLayout>
