---
import BookStackLayout from "../../layouts/BookStackLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { listItems } from "../../lib/itemQueries";
import { getMissingRequiredFields } from "../../lib/itemCompleteness";
import { t, tItemType } from "../../lib/i18n";

const lang = Astro.locals.lang;
const allItems = await listItems();

const groups = new Map<string, typeof allItems>();
for (const item of allItems) {
  if (!groups.has(item.type)) groups.set(item.type, []);
  groups.get(item.type)!.push(item);
}

const breadcrumbItems = [
  { label: t(lang, "nav.home"), href: "/", icon: "shelf" },
  { label: t(lang, "item.title"), href: "", icon: "book", current: true },
];
---

<BookStackLayout title="Items">
  <Breadcrumb items={breadcrumbItems} />
  <div class="home-wrap">
    <div class="page-hero">
      <h1>{t(lang, "item.title")}</h1>
      <p class="tagline">{t(lang, "item.tagline")}</p>
    </div>

    {Astro.locals.user && <a class="new-page-link" href="/items/new">{t(lang, "item.new")}</a>}

    {allItems.length === 0 && <p class="no-changes">{t(lang, "item.none")}</p>}

    {
      [...groups.entries()].map(([type, items]) => (
        <div class="shelf-block">
          <div class="shelf-block-header">
            <h2>{tItemType(lang, type)}</h2>
            <span style="color:var(--muted); font-size:0.78rem;">{items.length} {items.length === 1 ? t(lang, "item.item") : t(lang, "item.items")}</span>
          </div>
          <table class="collection-table">
            <thead>
              <tr>
                <th>{t(lang, "item.title")}</th>
                <th>{t(lang, "item.collection")}</th>
                <th>{t(lang, "home.status")}</th>
              </tr>
            </thead>
            <tbody>
              {items.map((item) => {
                const missing = getMissingRequiredFields(item.type, item.fields);
                return (
                  <tr>
                    <td><a class="row-title" href={`/items/${item.slug}`}>{item.name}</a></td>
                    <td style="color:var(--muted);">{item.collectionTitle}</td>
                    <td>
                      {item.status === "archived" ? (
                        <span class="status-chip status-chip--empty">{t(lang, "item.archived")}</span>
                      ) : missing.length > 0 ? (
                        <span class="status-chip status-chip--warning">{t(lang, "item.incompleteBadge")}</span>
                      ) : (
                        <span class="status-chip status-chip--active"><span class="dot" />{t(lang, "home.active")}</span>
                      )}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      ))
    }
  </div>
</BookStackLayout>
