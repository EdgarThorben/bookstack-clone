---
import BookStackLayout from "../../../layouts/BookStackLayout.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import DetailRowsEditor from "../../../components/DetailRowsEditor.astro";
import { actions } from "astro:actions";
import { getItemBySlug } from "../../../lib/itemQueries";
import { t } from "../../../lib/i18n";

const lang = Astro.locals.lang;

if (!Astro.locals.user) {
  return Astro.redirect("/login");
}

const { slug } = Astro.params;
const item = slug ? await getItemBySlug(slug) : null;

if (!item) {
  Astro.response.status = 404;
  return Astro.rewrite("/404");
}

const result = Astro.getActionResult(actions.updateItem);

if (result && !result.error) {
  return Astro.redirect(`/items/${result.data.slug}`);
}

const backHref = `/items/${item.slug}`;

const breadcrumbItems = [
  { label: t(lang, "nav.home"), href: "/", icon: "shelf" },
  { label: t(lang, "item.title"), href: "/items", icon: "book" },
  { label: item.name, href: backHref, icon: "page" },
  { label: t(lang, "details.edit"), href: "", icon: "page", current: true },
];
---

<BookStackLayout title={`Edit — ${item.name}`}>
  <Breadcrumb items={breadcrumbItems} />
  <div class="home-wrap">
    <h1>{t(lang, "item.editTitle")}</h1>
    {result?.error && <p class="login-error">{result.error.message}</p>}

    <form class="page-form" method="POST" action={actions.updateItem}>
      <input type="hidden" name="slug" value={item.slug} />

      <label>
        {t(lang, "item.name")}
        <input type="text" name="name" required value={item.name} />
      </label>

      <label>
        {t(lang, "item.region")} <span style="font-weight:400;color:var(--bs-muted);">{t(lang, "item.regionHint")}</span>
        <input type="text" name="region" value={item.region ?? ""} />
      </label>

      <label>
        {t(lang, "item.imageUrl")} <span style="font-weight:400;color:var(--bs-muted);">{t(lang, "item.imageUrlHint")}</span>
        <input type="url" name="imageUrl" value={item.imageUrl ?? ""} />
      </label>

      <label>
        {t(lang, "item.warning")} <span style="font-weight:400;color:var(--bs-muted);">{t(lang, "item.warningHint")}</span>
        <textarea name="warning">{item.warning ?? ""}</textarea>
      </label>

      <label>{t(lang, "item.fields")}</label>
      <DetailRowsEditor initialDetails={item.fields} fieldName="fields" />

      <label>
        {t(lang, "item.editSummary")} <span style="font-weight:400;color:var(--bs-muted);">{t(lang, "item.editSummaryHint")}</span>
        <input type="text" name="summary" placeholder={t(lang, "item.editSummaryPlaceholder")} />
      </label>

      <div class="form-actions">
        <button type="submit" class="primary-button">{t(lang, "item.saveChanges")}</button>
        <a href={backHref} class="secondary-button">{t(lang, "item.cancel")}</a>
      </div>
    </form>
  </div>
</BookStackLayout>
