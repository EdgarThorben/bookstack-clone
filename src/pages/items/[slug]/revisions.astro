---
import BookStackLayout from "../../../layouts/BookStackLayout.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import { getItemBySlug, getItemRevisions } from "../../../lib/itemQueries";
import { formatRelativeTime } from "../../../lib/time";
import { t } from "../../../lib/i18n";

const lang = Astro.locals.lang;
const { slug } = Astro.params;
const item = slug ? await getItemBySlug(slug) : null;

if (!item) {
  Astro.response.status = 404;
  return Astro.rewrite("/404");
}

const revisionData = await getItemRevisions(item.slug);
const revisions = revisionData?.revisions ?? [];
const backHref = `/items/${item.slug}`;

const breadcrumbItems = [
  { label: t(lang, "nav.home"), href: "/", icon: "shelf" },
  { label: t(lang, "item.title"), href: "/items", icon: "book" },
  { label: item.name, href: backHref, icon: "page" },
  { label: t(lang, "details.revisions"), href: "", icon: "page", current: true },
];
---

<BookStackLayout title={`Revisions — ${item.name}`}>
  <Breadcrumb items={breadcrumbItems} />
  <div class="home-wrap">
    <h1>{t(lang, "revisions.title")}</h1>
    <p style="color:var(--bs-muted); margin-bottom:1.5rem;">
      {t(lang, "revisions.intro")} <a href={backHref}>{item.name}</a>. {t(lang, "revisions.introEnd")}
    </p>

    {
      revisions.map((rev, i) => (
        <details class="revision-block" open={i === 0}>
          <summary>
            <span class="rev-num">{t(lang, "details.revision")} #{rev.revisionNo}</span>
            <span class="rev-meta">
              {formatRelativeTime(rev.createdAt, lang)} {t(lang, "details.by")} {rev.authorName ?? t(lang, "common.unknown")}
            </span>
            <span class="rev-summary">{rev.summary}</span>
          </summary>
          {rev.changes.length > 0 ? (
            <div class="nested-changes">
              <table class="detail-table">
                <thead>
                  <tr>
                    <th>{t(lang, "revisions.field")}</th>
                    <th>{t(lang, "revisions.previous")}</th>
                    <th>{t(lang, "revisions.new")}</th>
                  </tr>
                </thead>
                <tbody>
                  {rev.changes.map((c) => (
                    <tr>
                      <td>{c.field}</td>
                      <td class="diff-old">{c.from}</td>
                      <td class="diff-new">{c.to}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          ) : (
            <p class="no-changes">{t(lang, "revisions.noChanges")}</p>
          )}
        </details>
      ))
    }

    <a class="back-link" href={backHref}>{t(lang, "revisions.back")} {item.name}</a>
  </div>
</BookStackLayout>
