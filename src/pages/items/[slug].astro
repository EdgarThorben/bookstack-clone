---
import BookStackLayout from "../../layouts/BookStackLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import ItemSidebar from "../../components/ItemSidebar.astro";
import DetailsPanel from "../../components/DetailsPanel.astro";
import RelationshipsPanel from "../../components/RelationshipsPanel.astro";
import CredentialsPanel from "../../components/CredentialsPanel.astro";
import Badge from "../../components/Badge.astro";
import OnboardingGuideContent from "../../components/OnboardingGuideContent.astro";
import HolidayPartyContent from "../../components/HolidayPartyContent.astro";
import OutagePlanContent from "../../components/OutagePlanContent.astro";
import { actions } from "astro:actions";
import { getItemBySlug, getItemRelationships, getCollectionBySlug, listItems } from "../../lib/itemQueries";
import { getCredentialsForItem } from "../../lib/credentialQueries";
import { groupDetailsByCategory } from "../../lib/details";
import { getMissingRequiredFields } from "../../lib/itemCompleteness";
import { formatRelativeTime } from "../../lib/time";
import { breadcrumbForItem } from "../../lib/breadcrumbs";
import { t, tItemType } from "../../lib/i18n";

const lang = Astro.locals.lang;
const { slug } = Astro.params;
const item = slug ? await getItemBySlug(slug) : null;

if (!item) {
  Astro.response.status = 404;
  return Astro.rewrite("/404");
}

const relateResult = Astro.getActionResult(actions.addItemRelationship);
const archiveResult = Astro.getActionResult(actions.archiveItem);
const credentialResult = Astro.getActionResult(actions.createCredential);
if (
  (relateResult && !relateResult.error) ||
  (archiveResult && !archiveResult.error) ||
  (credentialResult && !credentialResult.error)
) {
  return Astro.redirect(`/items/${item.slug}`);
}

const categories = groupDetailsByCategory(item.fields);
const missingFields = getMissingRequiredFields(item.type, item.fields);
const { outgoing, incoming } = await getItemRelationships(item.id);
const otherItems = (await listItems()).filter((i) => i.id !== item.id);
const credentialItems = await getCredentialsForItem(item.id);
const collection = await getCollectionBySlug(item.collectionSlug);

const sections = new Map<string, { slug: string; name: string }[]>();
for (const collectionItem of collection?.items ?? []) {
  const key = collectionItem.section ?? "";
  if (!sections.has(key)) sections.set(key, []);
  sections.get(key)!.push({ slug: collectionItem.slug, name: collectionItem.name });
}
const sidebarSections = [...sections.entries()].map(([title, items]) => ({
  title: title || null,
  items,
}));

const bespokeContent: Record<string, typeof OnboardingGuideContent> = {
  "member-onboarding-guide": OnboardingGuideContent,
  "it-holiday-party-event": HolidayPartyContent,
  "server-outage-plan": OutagePlanContent,
};
const bespokeNav: Record<string, { href: string; label: string }[]> = {
  "member-onboarding-guide": [
    { href: "#checklist", label: t(lang, "onboarding.navChecklist") },
    { href: "#resources", label: t(lang, "onboarding.navResources") },
  ],
  "it-holiday-party-event": [
    { href: "#details", label: t(lang, "holidayParty.details") },
    { href: "#schedule", label: t(lang, "holidayParty.schedule") },
  ],
  "server-outage-plan": [
    { href: "#severity-levels", label: t(lang, "outagePlan.navSeverity") },
    { href: "#response-steps", label: t(lang, "outagePlan.navResponse") },
  ],
};
const BespokeMain = bespokeContent[item.slug];
const pageNav = bespokeNav[item.slug] ?? [{ href: "#fields", label: t(lang, "item.fields") }];
---

<BookStackLayout title={item.name}>
  <Breadcrumb
    items={breadcrumbForItem({
      homeLabel: t(lang, "nav.home"),
      collectionTitle: item.collectionTitle,
      collectionSlug: item.collectionSlug,
      section: item.section,
      itemName: item.name,
    })}
  />
  <div class="bs-layout">
    <aside class="bs-side">
      <h4>{t(lang, "page.pageNav")}</h4>
      <ul class="page-nav-list">
        {pageNav.map((n, i) => <li><a href={n.href} class={i === 0 ? "active" : ""}>{n.label}</a></li>)}
      </ul>
      <h4>{t(lang, "page.collectionNav")}</h4>
      <ItemSidebar
        collectionTitle={item.collectionTitle}
        collectionHref={`/collections/${item.collectionSlug}`}
        sections={sidebarSections}
        activeSlug={item.slug}
      />
    </aside>

    <main class="bs-content">
      {
        BespokeMain ? (
          <BespokeMain name={item.name} fields={item.fields} />
        ) : (
          <>
            <h1>
              {item.name}
              {item.status === "archived" && <Badge tone="warning">{t(lang, "item.archived")}</Badge>}
            </h1>
            <p style="color:var(--bs-muted);">{tItemType(lang, item.type)}</p>

            {
              missingFields.length > 0 && (
                <div class="warning-box">
                  <span class="warn-icon">&#9888;</span>
                  <div>{t(lang, "item.missingFields")} {missingFields.join(", ")}</div>
                </div>
              )
            }

            {
              item.warning && (
                <div class="warning-box">
                  <span class="warn-icon">&#9888;</span>
                  <div>{item.warning}</div>
                </div>
              )
            }

            <h2 id="fields">{t(lang, "item.fields")}</h2>
            {categories.length === 0 && <p class="no-changes">{t(lang, "item.noFields")}</p>}
            {
              categories.map((group) => (
                <details class="category-details" open>
                  <summary>
                    {group.category || t(lang, "item.general")} <span class="cat-count">({group.items.length})</span>
                  </summary>
                  <div class="table-scroll">
                    <table class="detail-table">
                      <tbody>
                        {group.items.map((d) => (
                          <tr>
                            <th>{d.label}</th>
                            <td>{d.value}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </details>
              ))
            }

            {
              item.imageUrl && (
                <>
                  <h2>{t(lang, "item.image")}</h2>
                  <img class="server-image" src={item.imageUrl} alt={`Photo for ${item.name}`} />
                </>
              )
            }
          </>
        )
      }

      <RelationshipsPanel
        itemSlug={item.slug}
        outgoing={outgoing}
        incoming={incoming}
        otherItems={Astro.locals.user ? otherItems : []}
        canEdit={!!Astro.locals.user}
        relateError={relateResult?.error?.message}
      />

      {credentialResult?.error && <p class="login-error">{credentialResult.error.message}</p>}
      <CredentialsPanel itemSlug={item.slug} items={credentialItems} canEdit={!!Astro.locals.user} />
    </main>

    <aside class="bs-side details-side">
      <DetailsPanel
        revision={item.currentRevision}
        createdBy={item.createdByName}
        createdAgo={formatRelativeTime(item.createdAt, lang)}
        updatedBy={item.updatedByName}
        updatedAgo={formatRelativeTime(item.updatedAt, lang)}
        revisionsHref={`/items/${item.slug}/revisions`}
        editHref={Astro.locals.user ? `/items/${item.slug}/edit` : undefined}
        exportData={item.fields}
        exportFilename={item.slug}
        exportTitle={item.name}
      />
      {
        Astro.locals.user && item.status === "active" && (
          <form method="POST" action={actions.archiveItem} style="margin-top:1rem;">
            <input type="hidden" name="slug" value={item.slug} />
            <button type="submit" class="secondary-button">{t(lang, "item.archiveButton")}</button>
          </form>
        )
      }
    </aside>
  </div>
</BookStackLayout>
